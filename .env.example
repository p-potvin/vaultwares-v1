# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AIzaSyBbw83tkKyssEQAWQxDDXSLWfKrrrjYiOM"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://vaultwares.com"

# DATABASE_URL: The connection string for the PostgreSQL database.
# For local development: postgresql://user:password@localhost:5432/vaultwares
# For Google Cloud SQL: postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME
DATABASE_URL=vaultwares:us-central1:vaultwares-database
# VITE_API_BASE_URL: The base URL for the backend API.
VITE_API_BASE_URL="http://127.0.0.1:9001"
