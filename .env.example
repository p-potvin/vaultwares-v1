# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AIzaSyBbw83tkKyssEQAWQxDDXSLWfKrrrjYiOM"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://vaultwares.com"

# JWT_SECRET: Secret key for signing JSON Web Tokens. REQUIRED in production.
JWT_SECRET=your_jwt_secret_here

# DATABASE_URL: Standard PostgreSQL connection string (used by Vercel Postgres and most providers).
# Takes priority over individual DB_* variables.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/vaultwares

# Individual DB vars (alternative to DATABASE_URL, used for Cloud SQL / local dev):
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=vaultwares
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Cloud SQL connection name (Google Cloud Run only):
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
